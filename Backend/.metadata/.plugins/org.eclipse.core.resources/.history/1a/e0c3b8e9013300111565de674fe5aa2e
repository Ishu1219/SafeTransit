SELECT 'Admin', 'Admin@gmail.com', '9999999999',
       'admin123',
       'ADMINISTRATOR', 'ACTIVE', NOW(), NOW()
WHERE NOT EXISTS (SELECT 1 FROM users WHERE email = 'admin@gmail.com');


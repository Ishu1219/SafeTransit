    // =========================
    // DELETE (Soft delete User)
    // =========================
    @Override
    public FleetManager deleteFleetManager(Long id) {

        FleetManager fleetManager =
                fleetManagerRepository.findByFleetManagerId(id);

        if (fleetManager == null) {
            throw new NotExistException(
                    "Fleet Manager not found with id: " + id);
        }

        fleetManagerRepository.delete(fleetManager);

        return fleetManager;
    }

    // =========================
    // UPDATE (Single request)
    // =========================
    @Override
    public FleetManagerResponse updateFleetManager(
            Long id, UpdateFleetManagerRequest request) {

        FleetManager fleetManager =
                fleetManagerRepository.findById(id)
                        .orElseThrow(() ->
                                new NotExistException(
                                        "Fleet Manager not found with id: " + id));

        User user = fleetManager.getUser();

        // -------- FleetManager fields --------
        if (request.getName() != null) {
            fleetManager.setName(request.getName());
            user.setName(request.getName());
        }

        if (request.getEmail() != null) {
            fleetManager.setEmail(request.getEmail());
            user.setEmail(request.getEmail());
        }

        if (request.getPhone() != null) {
            fleetManager.setPhone(request.getPhone());
            user.setPhone(request.getPhone());
        }

        if (request.getEmergencyContact() != null) {
            fleetManager.setEmergencyContact(request.getEmergencyContact());
        }

        if (request.getAddress() != null) {
            fleetManager.setAddress(request.getAddress());
        }

        if (request.getBloodGroup() != null) {
            fleetManager.setBloodGroup(request.getBloodGroup());
        }

        if (request.getSex() != null) {
            fleetManager.setSex(request.getSex());
        }

        if (request.getStatus() != null) {
            fleetManager.setStatus(request.getStatus());
            user.setStatus(UserStatus.USER_UPDATED);
        }

        // -------- Save --------
        userRepository.save(user);
        FleetManager updated =
                fleetManagerRepository.save(fleetManager);

        return FleetManagerMapper.toResponse(updated);
    }

    // =========================
    // GET BY ID
    // =========================
    @Override
    public FleetManagerResponse getFleetManagerById(Long id) {

        FleetManager fleetManager =
                fleetManagerRepository.findById(id)
                        .orElseThrow(() ->
                                new NotExistException(
                                        "Fleet Manager not found with id: " + id));

        return FleetManagerMapper.toResponse(fleetManager);
    }

    // =========================
    // GET ALL
    // =========================
    @Override
    public List<FleetManagerResponse> getAllFleetManagers() {

        return fleetManagerRepository.findAll()
                .stream()
                .map(FleetManagerMapper::toResponse)
                .collect(Collectors.toList());
    }
}

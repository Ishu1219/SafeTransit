package com.cts.service.imp;

import com.cts.dto.request.CreateDispatcherRequest;
import com.cts.dto.request.UpdateDispatcherRequest;
import com.cts.dto.response.DispatcherResponse;
import com.cts.entity.Dispatcher;
import com.cts.entity.User;
import com.cts.enums.AuditAction;
import com.cts.enums.Role;
//import com.cts.enums.UserStatus;
import com.cts.exception.NotExistException;
import com.cts.mapper.DispatcherMapper;
import com.cts.mapper.UserMapper;
import com.cts.repository.DispatcherRepository;
import com.cts.repository.UserRepository;
import com.cts.service.DispatcherService;

import jakarta.transaction.Transactional;
import lombok.RequiredArgsConstructor;

import org.springframework.security.crypto.password.PasswordEncoder;
import org.springframework.stereotype.Service;

import java.util.List;

@Service
@RequiredArgsConstructor
@Transactional
public class DispatcherServiceImpl implements DispatcherService {

    private final DispatcherRepository dispatcherRepository;
    private final UserRepository userRepository;
    private final PasswordEncoder passwordEncoder;
    
    @Override
    public DispatcherResponse createDispatcher(CreateDispatcherRequest request) {
    	//Saving User
    	
        Dispatcher existing = dispatcherRepository.findByEmail(request.getEmail());
        if (existing != null) {
            throw new RuntimeException("Dispatcher already exists with email: " + request.getEmail());
        }
        String encodedPassword = passwordEncoder.encode(request.getPassword());
        User user = UserMapper.createUser(
                request.getName(),
                request.getEmail(),
                request.getPhone(),
                encodedPassword,
                Role.DISPATCHER
        );

        userRepository.save(user);
        Dispatcher dispatcher = DispatcherMapper.toEntity(request,user);
        Dispatcher saved = dispatcherRepository.save(dispatcher);

        return DispatcherMapper.toResponse(saved);
    }

    @Override
    public DispatcherResponse updateDispatcher(Long id, UpdateDispatcherRequest request) {

        Dispatcher dispatcher = dispatcherRepository.findById(id)
                .orElseThrow(() -> new RuntimeException("Dispatcher not found with id: " + id));

        //Update Dispatcher fields
        if (request.getName() != null) dispatcher.setName(request.getName());
        if (request.getPhone() != null) dispatcher.setPhone(request.getPhone());
        if (request.getEmergencyContact() != null) dispatcher.setEmergencyContact(request.getEmergencyContact());
        if (request.getAddress() != null) dispatcher.setAddress(request.getAddress());
        if (request.getBloodGroup() != null) dispatcher.setBloodGroup(request.getBloodGroup());

        if (request.getStatus() != null) {
            dispatcher.setStatus(AuditAction.valueOf(request.getStatus().toUpperCase()));
        }

        //Update User table as well
        User user = dispatcher.getUser();
        if (user == null) {
            throw new RuntimeException("User not found for dispatcher email: " + dispatcher.getEmail());
        }
        if(request.getEmail()!=null) {
        	user.setEmail(request.getEmail());
        }
        if(request.getPassword()!=null) {
        	user.setPassword(request.getPassword());
        }
        if(request.getName()!=null) {
        	user.setName(request.getName());
        }
        if(request.getPhone()!=null) {
        	user.setPhone(request.getPhone());
        }
        userRepository.save(user);

        //Save Dispatcher
        Dispatcher saved = dispatcherRepository.save(dispatcher);
        return DispatcherMapper.toResponse(saved);
    }
    
    @Override
    public DispatcherResponse getDispatcherById(Long id) {
        Dispatcher dispatcher = dispatcherRepository.findById(id)
                .orElseThrow(() -> new RuntimeException("Dispatcher not found with id: " + id));
        return DispatcherMapper.toResponse(dispatcher);
    }

    @Override
    public List<DispatcherResponse> getAllDispatchers() {
        return dispatcherRepository.findAll()
                .stream()
                .map(DispatcherMapper::toResponse)
                .toList();
    }

    @Override
    public void deleteDispatcher(Long id) {
        Dispatcher dispatcher = dispatcherRepository.findById(id)
                .orElseThrow(() -> new RuntimeException("Dispatcher not found with id: " + id));
        User user = userRepository.findByEmail(dispatcher.getEmail());
        if (user == null) {
            throw new NotExistException("User not found for passenger email: " + dispatcher.getEmail());
        }
//        userRepository.delete(dispatcher);
        
        dispatcherRepository.delete(dispatcher);   
    }
}